[build-system]
requires = ["setuptools>=61.0"]
build-backend = "setuptools.build_meta"

[project]
name = "fervoja"
version = "0.0.1"
description = "Rail protocol messages format library."
readme = "README.md"
requires-python = ">=3.8"
license = { text = "GPLv3" }
authors = [
    { name = "Álvaro Pauner Argudo", email = ".project@gmail.com" }
]
classifiers = [
    "Development Status :: 3 - Alpha",
    "Intended Audience :: Developers",
    "Topic :: Communications",
    "Programming Language :: Python :: 3",
    "Operating System :: OS Independent",
]

dependencies = []

[project.optional-dependencies]
test = [
    "pytest>=7.0.0",
    "coverage>=7.0.0",
    "pytest-cov>=7.1.0",
]

[project.urls]
"Homepage" = "https://github.com/23albatross23/fervoja"
"Bug Tracker" = "https://github.com/23albatross23/fervoja/issues"

[tool.pytest.ini_options]
minversion = "7.0"
addopts = """
    --cov=fervoja 
    --cov-report=term-missing 
    --cov-report=html 
    --cov-context=test 
    -ra -v
"""
testpaths = [
    "tests",
]

[tool.coverage.run]
branch = true
source = ["fervoja"]

[tool.coverage.report]
exclude_lines = [
    "pragma: no cover",
    "def __repr__",
    "if self.debug:",
    "raise NotImplementedError",
    "if __name__ == .__main__.:",
    "pass",
    "abstractmethod"
]
skip_empty = true

[tool.coverage.html]
show_contexts = true
title = "fervoja Coverage Report"

[tool.setuptools.packages.find]
include = ["fervoja*"]
exclude = ["fervoja_env*", "tests*"]